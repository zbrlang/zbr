use crate::context::{DiscordContext, FnOutput};
use serenity::model::id::GuildId;

/// ZchannelID{}       — current channel's ID
/// ZchannelID{name}   — find channel by name in the guild
pub fn run(args: Vec<String>, ctx: &DiscordContext) -> FnOutput {
    let query = args.get(0).filter(|s| !s.is_empty()).cloned().unwrap_or_default();
    if query.is_empty() {
        return FnOutput::Text(ctx.channel_id.clone());
    }

    let http = match &ctx.http {
        Some(h) => h.clone(),
        None => return FnOutput::error("channelID", "no HTTP client available"),
    };

    let guild_id: u64 = match ctx.guild_id.parse() {
        Ok(id) => id,
        Err(_) => return FnOutput::error("channelID", crate::error_messages::not_in_guild()),
    };

    let result = tokio::task::block_in_place(|| {
        tokio::runtime::Handle::current().block_on(async move {
            let channels = GuildId::new(guild_id)
                .channels(&http)
                .await
                .map_err(|e| format!("failed to fetch channels: {}", e))?;

            let q = query.to_lowercase();
            for channel in channels.values() {
                if channel.name.to_lowercase() == q {
                    return Ok(channel.id.to_string());
                }
            }
            Err(format!("no channel found matching '{}'", query))
        })
    });

    match result {
        Ok(id) => FnOutput::Text(id),
        Err(e) => FnOutput::error("channelID", e),
    }
}
